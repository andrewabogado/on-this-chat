{
  "manifest_version": 3,
  "name": "ChatGPT TOC Assistant",
  "version": "1.0",
  "description": "Generates a Table of Contents for ChatGPT conversations.",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}

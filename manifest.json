{
  "manifest_version": 3,
  "name": "On This Chat",
  "version": "1.1",
  "author": "Andrew Abogado (https://github.com/andrewabogado)",
  "description": "Generates table of contents for ChatGPT. Perfect for long conversations.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Toggle On This Chat"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}